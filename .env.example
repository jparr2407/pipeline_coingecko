AIRFLOW_UID=50000

# Airflow UI
AIRFLOW_ADMIN_USER=admin
AIRFLOW_ADMIN_PASSWORD=admin
AIRFLOW_ADMIN_EMAIL=admin@example.com

# Airflow metadata database
POSTGRES_AIRFLOW_USER=airflow
POSTGRES_AIRFLOW_PASSWORD=airflow
POSTGRES_AIRFLOW_DB=airflow

# Analytics warehouse exposed to the host for Power BI
WAREHOUSE_HOST=postgres-warehouse
WAREHOUSE_PORT=5432
WAREHOUSE_HOST_PORT=5433
WAREHOUSE_DB=crypto_warehouse
WAREHOUSE_USER=analytics
WAREHOUSE_PASSWORD=analytics

# CoinGecko
# Use "demo" for https://api.coingecko.com/api/v3 with header x-cg-demo-api-key.
# Use "pro" for https://pro-api.coingecko.com/api/v3 with header x-cg-pro-api-key.
COINGECKO_API_TIER=demo
COINGECKO_API_KEY=
COINGECKO_VS_CURRENCY=usd
COINGECKO_TOP_MARKETS=250
COINGECKO_HISTORY_TOP_COINS=20
COINGECKO_HISTORY_DAYS=90
COINGECKO_REQUEST_SLEEP_SECONDS=1.5
